--echo # vsql_statistics: covariance aggregate function

INSTALL EXTENSION vsql_statistics;
CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;

CREATE TABLE cov_data (x DOUBLE, y DOUBLE);

--echo # --- Spec Example 1: positive covariance X={2,4,6} Y={5,10,12}, n=3 ---
--echo # pop=14/3≈4.6667, samp=14/2=7.0
INSERT INTO cov_data VALUES (2,5),(4,10),(6,12);
SELECT CAST(STATS_COVARIANCE(x, y) AS CHAR) AS covariance FROM cov_data;
DELETE FROM cov_data;

--echo # --- Spec Example 2: negative covariance X={1,3,5} Y={20,15,10}, n=3 ---
--echo # pop=-20/3≈-6.6667, samp=-20/2=-10.0
INSERT INTO cov_data VALUES (1,20),(3,15),(5,10);
SELECT CAST(STATS_COVARIANCE(x, y) AS CHAR) AS covariance FROM cov_data;
DELETE FROM cov_data;

--echo # --- Perfectly correlated X={1,2,3,4,5} Y={2,4,6,8,10}: pop=4.0, samp=5.0 ---
INSERT INTO cov_data VALUES (1,2),(2,4),(3,6),(4,8),(5,10);
SELECT CAST(STATS_COVARIANCE(x, y) AS CHAR) AS covariance FROM cov_data;
DELETE FROM cov_data;

--echo # --- n=1: pop=0.0, samp=null ---
INSERT INTO cov_data VALUES (3,7);
SELECT CAST(STATS_COVARIANCE(x, y) AS CHAR) AS covariance FROM cov_data;
DELETE FROM cov_data;

--echo # --- All-NULL: returns NULL ---
INSERT INTO cov_data VALUES (NULL,NULL),(NULL,NULL);
SELECT CAST(STATS_COVARIANCE(x, y) AS CHAR) AS covariance FROM cov_data;
DELETE FROM cov_data;

--echo # --- NULL pair skipping: (2,5) kept; (NULL,10) and (6,NULL) dropped → n=1 ---
INSERT INTO cov_data VALUES (2,5),(NULL,10),(6,NULL);
SELECT CAST(STATS_COVARIANCE(x, y) AS CHAR) AS covariance FROM cov_data;
DELETE FROM cov_data;

DROP TABLE cov_data;

--echo # --- GROUP BY: covariance computed independently per group ---
CREATE TABLE vsql_test.cov_grouped (grp INT, x DOUBLE, y DOUBLE);
INSERT INTO cov_grouped VALUES
  (1, 2,5),(1, 4,10),(1, 6,12),
  (2, 1,20),(2, 3,15),(2, 5,10);
SELECT grp,
       CAST(STATS_COVARIANCE(x, y) AS CHAR) AS covariance
FROM vsql_test.cov_grouped
GROUP BY grp
ORDER BY grp;
DROP TABLE vsql_test.cov_grouped;

DROP DATABASE vsql_test;
UNINSTALL EXTENSION vsql_statistics;
