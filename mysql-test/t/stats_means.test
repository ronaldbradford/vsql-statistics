--echo # vsql_statistics: trimmed, Winsorized, geometric, and harmonic means

INSTALL EXTENSION vsql_statistics;
CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;

--echo # --- Spec example {2,10,12,14,15,18,100} at 20% trim ---
--echo # trimmed: removes 1 from each end → mean({10,12,14,15,18})=13.8
--echo # winsorized: 2→10, 100→18; sum=97, mean=97/7≈13.857
--echo # geometric: ⁷√(2×10×12×14×15×18×100)
--echo # harmonic: 7/(1/2+1/10+1/12+1/14+1/15+1/18+1/100)
CREATE TABLE means_data (val DOUBLE, trim_pct DOUBLE);
INSERT INTO means_data VALUES (2,0.2),(10,0.2),(12,0.2),(14,0.2),(15,0.2),(18,0.2),(100,0.2);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
DELETE FROM means_data;

--echo # --- trim=0: trimmed/winsorized equal arithmetic mean ---
INSERT INTO means_data VALUES (2,0),(10,0),(12,0),(14,0),(15,0),(18,0),(100,0);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
DELETE FROM means_data;

--echo # --- NULL trim_pct: trimmed and winsorized are null ---
INSERT INTO means_data VALUES (1.05,NULL),(1.10,NULL),(1.20,NULL);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
DELETE FROM means_data;

--echo # --- Degenerate trim (all values removed): trimmed/winsorized null ---
--echo # trim_pct=0.5, n=2: k=floor(0.5*2)=1, 2k=2>=n=2
INSERT INTO means_data VALUES (10,0.5),(20,0.5);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
DELETE FROM means_data;

--echo # --- All-NULL values: whole result is NULL ---
INSERT INTO means_data VALUES (NULL,0.2),(NULL,0.2);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
DELETE FROM means_data;

--echo # --- Non-positive values: skipped for geometric/harmonic ---
INSERT INTO means_data VALUES (-1,0.2),(0,0.2),(10,0.2),(20,0.2),(30,0.2);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
DELETE FROM means_data;

--echo # --- All non-positive: geometric/harmonic are null ---
INSERT INTO means_data VALUES (-5,NULL),(-3,NULL),(0,NULL);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
DELETE FROM means_data;

DROP TABLE means_data;

--echo # --- GROUP BY: means computed independently per group ---
CREATE TABLE vsql_test.means_grouped (grp INT, val DOUBLE, trim_pct DOUBLE);
INSERT INTO means_grouped VALUES
  (1, 2,   0.2),(1, 10,  0.2),(1, 12,  0.2),(1, 14,  0.2),
  (1, 15,  0.2),(1, 18,  0.2),(1, 100, 0.2),
  (2, 1.05,NULL),(2, 1.10,NULL),(2, 1.20,NULL);
SELECT grp,
       CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means
FROM vsql_test.means_grouped
GROUP BY grp
ORDER BY grp;
DROP TABLE vsql_test.means_grouped;

DROP DATABASE vsql_test;
UNINSTALL EXTENSION vsql_statistics;
