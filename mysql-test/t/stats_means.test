# vsql_statistics: trimmed mean, Winsorized mean, geometric mean, harmonic mean
INSTALL EXTENSION vsql_statistics;
CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;

# --- Trimmed mean: spec example {2,10,12,14,15,18,100} at 20% trim ---
# Removes 1 value from each end (floor(0.2*7)=1); mean of {10,12,14,15,18} = 13.8
CREATE TABLE means_data (val DOUBLE, trim_pct DOUBLE);
INSERT INTO means_data VALUES (2,0.2),(10,0.2),(12,0.2),(14,0.2),(15,0.2),(18,0.2),(100,0.2);
SELECT STATS_MEAN_TRIMMED(val, trim_pct) AS trimmed FROM means_data;

# --- Winsorized mean: spec example {2,10,12,14,15,18,100} at 20% ---
# Replaces 2 with 10 and 100 with 18; sum=97, mean=97/7≈13.86
SELECT ROUND(STATS_MEAN_WINSORIZED(val, trim_pct), 2) AS winsorized FROM means_data;

# --- trim=0 returns the arithmetic mean ---
DELETE FROM means_data;
INSERT INTO means_data VALUES (2,0),(10,0),(12,0),(14,0),(15,0),(18,0),(100,0);
SELECT ROUND(STATS_MEAN_TRIMMED(val, trim_pct), 4)    AS trimmed_0  FROM means_data;
SELECT ROUND(STATS_MEAN_WINSORIZED(val, trim_pct), 4) AS winsorized_0 FROM means_data;

# --- All-NULL: both functions return NULL ---
DELETE FROM means_data;
INSERT INTO means_data VALUES (NULL,0.2),(NULL,0.2);
SELECT STATS_MEAN_TRIMMED(val, trim_pct)    AS trimmed_null   FROM means_data;
SELECT STATS_MEAN_WINSORIZED(val, trim_pct) AS winsorized_null FROM means_data;

# --- Degenerate trim (all values removed/replaced): returns NULL ---
# trim_pct=0.5, n=2: k=floor(0.5*2)=1, 2k=2>=n=2 → NULL
DELETE FROM means_data;
INSERT INTO means_data VALUES (10,0.5),(20,0.5);
SELECT STATS_MEAN_TRIMMED(val, trim_pct)    AS trimmed_degen   FROM means_data;
SELECT STATS_MEAN_WINSORIZED(val, trim_pct) AS winsorized_degen FROM means_data;

DROP TABLE means_data;

# --- Geometric mean: spec example investment growth {1.05, 1.10, 1.20} ---
# ³√(1.05×1.10×1.20) = ³√1.386 ≈ 1.1149
CREATE TABLE geo_data (val DOUBLE);
INSERT INTO geo_data VALUES (1.05),(1.10),(1.20);
SELECT ROUND(STATS_MEAN_GEOMETRIC(val), 4) AS geo_mean FROM geo_data;

# --- Geometric mean: non-positive values are skipped ---
DELETE FROM geo_data;
INSERT INTO geo_data VALUES (-1),(0),(1.05),(1.10),(1.20);
SELECT ROUND(STATS_MEAN_GEOMETRIC(val), 4) AS geo_skip_nonpos FROM geo_data;

# --- Geometric mean: all-NULL or all non-positive returns NULL ---
DELETE FROM geo_data;
INSERT INTO geo_data VALUES (NULL),(NULL);
SELECT STATS_MEAN_GEOMETRIC(val) AS geo_null FROM geo_data;

DELETE FROM geo_data;
INSERT INTO geo_data VALUES (-5),(-3),(0);
SELECT STATS_MEAN_GEOMETRIC(val) AS geo_nonpos FROM geo_data;

DROP TABLE geo_data;

# --- Harmonic mean: spec example average speed {40, 60} ---
# 2 / (1/40 + 1/60) = 48.0
CREATE TABLE harm_data (val DOUBLE);
INSERT INTO harm_data VALUES (40),(60);
SELECT ROUND(STATS_MEAN_HARMONIC(val), 1) AS harm_mean FROM harm_data;

# --- Harmonic mean: non-positive values are skipped ---
DELETE FROM harm_data;
INSERT INTO harm_data VALUES (-1),(0),(40),(60);
SELECT ROUND(STATS_MEAN_HARMONIC(val), 1) AS harm_skip_nonpos FROM harm_data;

# --- Harmonic mean: all-NULL or all non-positive returns NULL ---
DELETE FROM harm_data;
INSERT INTO harm_data VALUES (NULL),(NULL);
SELECT STATS_MEAN_HARMONIC(val) AS harm_null FROM harm_data;

DELETE FROM harm_data;
INSERT INTO harm_data VALUES (-5),(-3);
SELECT STATS_MEAN_HARMONIC(val) AS harm_nonpos FROM harm_data;

DROP TABLE harm_data;

# --- GROUP BY: all four functions computed independently per group ---
CREATE TABLE vsql_test.means_grouped (grp INT, val DOUBLE, trim_pct DOUBLE);
INSERT INTO means_grouped VALUES
  (1, 2,   0.2),(1, 10,  0.2),(1, 12,  0.2),(1, 14,  0.2),
  (1, 15,  0.2),(1, 18,  0.2),(1, 100, 0.2),
  (2, 1.05,0.0),(2, 1.10,0.0),(2, 1.20,0.0);
SELECT grp,
  STATS_MEAN_TRIMMED(val, trim_pct)              AS trimmed,
  ROUND(STATS_MEAN_GEOMETRIC(val), 4)            AS geo_mean,
  ROUND(STATS_MEAN_HARMONIC(val), 4)             AS harm_mean
FROM vsql_test.means_grouped
GROUP BY grp
ORDER BY grp;
DROP TABLE vsql_test.means_grouped;

DROP DATABASE vsql_test;
UNINSTALL EXTENSION vsql_statistics;
