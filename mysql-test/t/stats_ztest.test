--echo # vsql_statistics: one-sample z-test aggregate function

INSTALL EXTENSION vsql_statistics;

CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;
CREATE TABLE ztest_data (val DOUBLE);

--echo # --- Spec reference: n=40, mean=511.0775, mu=500, sigma=40 → Z≈1.7515, p_two≈0.0799 ---
INSERT INTO ztest_data VALUES
  (511.0775),(511.0775),(511.0775),(511.0775),(511.0775),
  (511.0775),(511.0775),(511.0775),(511.0775),(511.0775),
  (511.0775),(511.0775),(511.0775),(511.0775),(511.0775),
  (511.0775),(511.0775),(511.0775),(511.0775),(511.0775),
  (511.0775),(511.0775),(511.0775),(511.0775),(511.0775),
  (511.0775),(511.0775),(511.0775),(511.0775),(511.0775),
  (511.0775),(511.0775),(511.0775),(511.0775),(511.0775),
  (511.0775),(511.0775),(511.0775),(511.0775),(511.0775);
SELECT CAST(STATS_ZTEST(val, 500.0, 40.0) AS CHAR) AS ztest FROM ztest_data;
DELETE FROM ztest_data;

--echo # --- Hand-verifiable: 4 equal values, mu=3, sigma=2 → Z=(4-3)/(2/2)=1.0 ---
INSERT INTO ztest_data VALUES (4),(4),(4),(4);
SELECT CAST(STATS_ZTEST(val, 3.0, 2.0) AS CHAR) AS ztest FROM ztest_data;
DELETE FROM ztest_data;

--echo # --- Single row: n=1 produces a valid Z-score (unlike t-test which requires n>=2) ---
INSERT INTO ztest_data VALUES (510.0);
SELECT CAST(STATS_ZTEST(val, 500.0, 40.0) AS CHAR) AS ztest FROM ztest_data;
DELETE FROM ztest_data;

--echo # --- All-NULL: returns NULL ---
INSERT INTO ztest_data VALUES (NULL),(NULL),(NULL);
SELECT CAST(STATS_ZTEST(val, 500.0, 40.0) AS CHAR) AS ztest FROM ztest_data;
DELETE FROM ztest_data;

--echo # --- sigma=0: returns NULL ---
INSERT INTO ztest_data VALUES (510.0),(520.0),(530.0);
SELECT CAST(STATS_ZTEST(val, 500.0, 0.0) AS CHAR) AS ztest FROM ztest_data;
DELETE FROM ztest_data;

--echo # --- Negative Z (mean < mu): p_one_tail > 0.5 ---
INSERT INTO ztest_data VALUES (490.0),(490.0),(490.0),(490.0);
SELECT CAST(STATS_ZTEST(val, 500.0, 2.0) AS CHAR) AS ztest FROM ztest_data;
SELECT JSON_VALUE(CAST(STATS_ZTEST(val, 500.0, 2.0) AS CHAR), '$.p_one_tail') + 0 > 0.5
  AS p_one_gt_half FROM ztest_data;
DELETE FROM ztest_data;

--echo # --- GROUP BY: Z-test computed independently per group ---
CREATE TABLE vsql_test.ztest_grouped (grp INT, val DOUBLE);
INSERT INTO ztest_grouped VALUES
  (1,4),(1,4),(1,4),(1,4),
  (2,3),(2,3),(2,3),(2,3),(2,3),(2,3),(2,3),(2,3),(2,3);
SELECT grp,
       CAST(STATS_ZTEST(val, 3.0, 2.0) AS CHAR) AS ztest
FROM vsql_test.ztest_grouped
GROUP BY grp
ORDER BY grp;
DROP TABLE vsql_test.ztest_grouped;

DROP TABLE ztest_data;
DROP DATABASE vsql_test;

UNINSTALL EXTENSION vsql_statistics;
