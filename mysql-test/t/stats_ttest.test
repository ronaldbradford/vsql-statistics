--echo # vsql_statistics: Two-sample t-test (pooled variance)

INSTALL EXTENSION vsql_statistics;

--echo # --- STATS_TTEST: inference statistics ---
--echo # Group 1: {100,110,120,130,140}  mean=120, var=250
--echo # Group 2: {  90,100,110,120,130} mean=110, var=250
--echo # pooled_var=250, df=8, t=1.0, alpha=0.05
CREATE TABLE ttest_basic (value DOUBLE, grp INT);
INSERT INTO ttest_basic VALUES
  (100,1),(110,1),(120,1),(130,1),(140,1),
  (90,2),(100,2),(110,2),(120,2),(130,2);

SELECT CAST(STATS_TTEST(value, grp, 0.05) AS CHAR) AS ttest FROM ttest_basic;

--echo # --- STATS_TTEST_GROUPS: per-group descriptives ---
SELECT CAST(STATS_TTEST_GROUPS(value, grp) AS CHAR) AS ttest_groups FROM ttest_basic;

--echo # --- Reversed groups: t negated; groups swap; two-tail values unchanged ---
SELECT CAST(STATS_TTEST(value, IF(grp=1,2,1), 0.05) AS CHAR) AS ttest_rev FROM ttest_basic;
SELECT CAST(STATS_TTEST_GROUPS(value, IF(grp=1,2,1)) AS CHAR) AS ttest_groups_rev FROM ttest_basic;

DROP TABLE ttest_basic;

--echo # --- Custom alpha=0.01: critical values larger than alpha=0.05 ---
CREATE TABLE ttest_alpha (value DOUBLE, grp INT);
INSERT INTO ttest_alpha VALUES
  (100,1),(110,1),(120,1),(130,1),(140,1),
  (90,2),(100,2),(110,2),(120,2),(130,2);

SELECT CAST(STATS_TTEST(value, grp, 0.01) AS CHAR) AS ttest_001 FROM ttest_alpha;

DROP TABLE ttest_alpha;

--echo # --- Edge case: only one group returns NULL ---
CREATE TABLE ttest_one_group (value DOUBLE, grp INT);
INSERT INTO ttest_one_group VALUES (10,1),(20,1),(30,1);
SELECT CAST(STATS_TTEST(value, grp, 0.05) AS CHAR)  AS ttest_one        FROM ttest_one_group;
SELECT CAST(STATS_TTEST_GROUPS(value, grp) AS CHAR) AS ttest_groups_one FROM ttest_one_group;
DROP TABLE ttest_one_group;

--echo # --- Edge case: group with fewer than 2 observations returns NULL ---
CREATE TABLE ttest_small_group (value DOUBLE, grp INT);
INSERT INTO ttest_small_group VALUES (5,1),(10,2),(20,2),(30,2);
SELECT CAST(STATS_TTEST(value, grp, 0.05) AS CHAR)  AS ttest_small        FROM ttest_small_group;
SELECT CAST(STATS_TTEST_GROUPS(value, grp) AS CHAR) AS ttest_groups_small FROM ttest_small_group;
DROP TABLE ttest_small_group;

--echo # --- Group labels other than 1 and 2 are ignored ---
--echo # grp 0, 3, and NULL rows dropped; result matches the basic dataset
CREATE TABLE ttest_labels (value DOUBLE, grp INT);
INSERT INTO ttest_labels VALUES
  (100,1),(110,1),(120,1),(130,1),(140,1),
  (90,2),(100,2),(110,2),(120,2),(130,2),
  (999,0),(999,3),(999,NULL);
SELECT CAST(STATS_TTEST(value, grp, 0.05) AS CHAR) AS ttest_labels FROM ttest_labels;
DROP TABLE ttest_labels;

--echo # --- NULL alpha: defaults to 0.05 (same output as the basic dataset) ---
CREATE TABLE ttest_null_alpha (value DOUBLE, grp INT, alpha DOUBLE);
INSERT INTO ttest_null_alpha VALUES
  (100,1,NULL),(110,1,NULL),(120,1,NULL),(130,1,NULL),(140,1,NULL),
  (90,2,NULL),(100,2,NULL),(110,2,NULL),(120,2,NULL),(130,2,NULL);
SELECT CAST(STATS_TTEST(value, grp, alpha) AS CHAR) AS ttest_default_alpha FROM ttest_null_alpha;
DROP TABLE ttest_null_alpha;

--echo # --- alpha taken from the single non-NULL row (NULL rows do not reset it) ---
CREATE TABLE ttest_one_alpha (value DOUBLE, grp INT, alpha DOUBLE);
INSERT INTO ttest_one_alpha VALUES
  (100,1,NULL),(110,1,0.01),(120,1,NULL),(130,1,NULL),(140,1,NULL),
  (90,2,NULL),(100,2,NULL),(110,2,NULL),(120,2,NULL),(130,2,NULL);
SELECT CAST(STATS_TTEST(value, grp, alpha) AS CHAR) AS ttest_single_alpha FROM ttest_one_alpha;
DROP TABLE ttest_one_alpha;

--echo # --- Zero pooled variance, equal means: t=0, p_two_tail=1 ---
CREATE TABLE ttest_zero_var_eq (value DOUBLE, grp INT);
INSERT INTO ttest_zero_var_eq VALUES (5,1),(5,1),(5,2),(5,2);
SELECT CAST(STATS_TTEST(value, grp, 0.05) AS CHAR) AS ttest_zero_eq FROM ttest_zero_var_eq;
DROP TABLE ttest_zero_var_eq;

--echo # --- Zero pooled variance, different means: returns NULL (t undefined) ---
CREATE TABLE ttest_zero_var_ne (value DOUBLE, grp INT);
INSERT INTO ttest_zero_var_ne VALUES (5,1),(5,1),(9,2),(9,2);
SELECT CAST(STATS_TTEST(value, grp, 0.05) AS CHAR) AS ttest_zero_ne FROM ttest_zero_var_ne;
DROP TABLE ttest_zero_var_ne;

--echo # --- Edge case: all-NULL values returns NULL ---
CREATE TABLE ttest_nulls (value DOUBLE, grp INT);
INSERT INTO ttest_nulls VALUES (NULL,1),(NULL,2);
SELECT CAST(STATS_TTEST(value, grp, 0.05) AS CHAR)  AS ttest_null        FROM ttest_nulls;
SELECT CAST(STATS_TTEST_GROUPS(value, grp) AS CHAR) AS ttest_groups_null FROM ttest_nulls;
DROP TABLE ttest_nulls;

UNINSTALL EXTENSION vsql_statistics;
