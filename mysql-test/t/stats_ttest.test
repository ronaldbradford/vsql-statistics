--echo # vsql_statistics: Two-sample t-test assuming equal variances (pooled-variance)

INSTALL EXTENSION vsql_statistics;

--echo # --- Two groups with DOUBLE value column: t=1.0 exactly ---
--echo # Group 1: {100,110,120,130,140}  mean=120, var=250
--echo # Group 2: { 90,100,110,120,130}  mean=110, var=250
--echo # pooled_var=250, df=8, t=(120-110)/sqrt(250*2/5)=1.0
CREATE TABLE ttest_basic (value DOUBLE, grp INT);
INSERT INTO ttest_basic VALUES
  (100,1),(110,1),(120,1),(130,1),(140,1),
  (90,2),(100,2),(110,2),(120,2),(130,2);

SELECT STATS_TTEST_T(value, grp)           AS t_stat        FROM ttest_basic;
SELECT STATS_TTEST_DF(value, grp)          AS df            FROM ttest_basic;
SELECT STATS_TTEST_POOLED_VAR(value, grp)  AS pooled_var    FROM ttest_basic;
SELECT STATS_TTEST_P_ONE_TAIL(value, grp)  AS p_one_tail    FROM ttest_basic;
SELECT STATS_TTEST_P_TWO_TAIL(value, grp)  AS p_two_tail    FROM ttest_basic;
SELECT STATS_TTEST_T_CRIT_ONE_TAIL(value, grp, 0.05) AS t_crit_one FROM ttest_basic;
SELECT STATS_TTEST_T_CRIT_TWO_TAIL(value, grp, 0.05) AS t_crit_two FROM ttest_basic;

--echo # --- Reversed groups produce negative t; two-tail p is symmetric ---
SELECT STATS_TTEST_T(value, IF(grp=1,2,1))          AS t_neg       FROM ttest_basic;
SELECT STATS_TTEST_P_TWO_TAIL(value, IF(grp=1,2,1)) AS p_two_same  FROM ttest_basic;

DROP TABLE ttest_basic;

--echo # --- INT value column returns integer-rounded results (expected VEF limitation) ---
--echo # Workaround: CAST(value AS DOUBLE) restores decimal precision.
CREATE TABLE ttest_int_col (v INT, grp INT);
INSERT INTO ttest_int_col VALUES
  (100,1),(110,1),(120,1),(130,1),(140,1),
  (90,2),(100,2),(110,2),(120,2),(130,2);

SELECT STATS_TTEST_P_TWO_TAIL(v, grp)                  AS p_int_rounded FROM ttest_int_col;
SELECT STATS_TTEST_P_TWO_TAIL(CAST(v AS DOUBLE), grp)  AS p_double_cast FROM ttest_int_col;

DROP TABLE ttest_int_col;

--echo # --- Edge case: only one group present returns NULL ---
CREATE TABLE ttest_one_group (value DOUBLE, grp INT);
INSERT INTO ttest_one_group VALUES (10,1),(20,1),(30,1);
SELECT STATS_TTEST_T(value, grp) AS t_one_group FROM ttest_one_group;
DROP TABLE ttest_one_group;

--echo # --- Edge case: group with fewer than 2 observations returns NULL ---
CREATE TABLE ttest_small_group (value DOUBLE, grp INT);
INSERT INTO ttest_small_group VALUES (5,1),(10,2),(20,2),(30,2);
SELECT STATS_TTEST_T(value, grp) AS t_small_group FROM ttest_small_group;
DROP TABLE ttest_small_group;

--echo # --- Edge case: all-NULL values returns NULL ---
CREATE TABLE ttest_nulls (value DOUBLE, grp INT);
INSERT INTO ttest_nulls VALUES (NULL,1),(NULL,2);
SELECT STATS_TTEST_T(value, grp) AS t_all_null FROM ttest_nulls;
DROP TABLE ttest_nulls;

--echo # --- Custom alpha: critical value at alpha=0.01 is larger than at alpha=0.05 ---
CREATE TABLE ttest_alpha (value DOUBLE, grp INT);
INSERT INTO ttest_alpha VALUES
  (100,1),(110,1),(120,1),(130,1),(140,1),
  (90,2),(100,2),(110,2),(120,2),(130,2);

SELECT
  STATS_TTEST_T_CRIT_TWO_TAIL(value, grp, 0.05) AS t_crit_005,
  STATS_TTEST_T_CRIT_TWO_TAIL(value, grp, 0.01) AS t_crit_001
FROM ttest_alpha;

DROP TABLE ttest_alpha;

UNINSTALL EXTENSION vsql_statistics;
