# vsql_statistics: skewness aggregate functions
INSTALL EXTENSION vsql_statistics;
CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;
CREATE TABLE skew_data (val DOUBLE);

# --- Symmetric dataset: both measures are zero ---
INSERT INTO skew_data VALUES (1),(2),(3),(4),(5);
SELECT CAST(STATS_SKEWNESS(val) AS CHAR) AS skewness FROM skew_data;
DELETE FROM skew_data;

# --- Right-skewed {2,4,4,4,5,5,7,9}: moment=0.65625, pearson=0.75 ---
INSERT INTO skew_data VALUES (2),(4),(4),(4),(5),(5),(7),(9);
SELECT CAST(STATS_SKEWNESS(val) AS CHAR) AS skewness FROM skew_data;
DELETE FROM skew_data;

# --- Right-skewed: moment must be positive ---
INSERT INTO skew_data VALUES (2),(2),(2),(2),(2),(2),(2),(100);
SELECT JSON_VALUE(CAST(STATS_SKEWNESS(val) AS CHAR), '$.moment') + 0 > 0 AS moment_positive FROM skew_data;
DELETE FROM skew_data;

# --- Left-skewed: moment must be negative ---
INSERT INTO skew_data VALUES (1),(100),(100),(100),(100),(100),(100),(100);
SELECT JSON_VALUE(CAST(STATS_SKEWNESS(val) AS CHAR), '$.moment') + 0 < 0 AS moment_negative FROM skew_data;
DELETE FROM skew_data;

# --- All-NULL: returns NULL ---
INSERT INTO skew_data VALUES (NULL),(NULL),(NULL);
SELECT CAST(STATS_SKEWNESS(val) AS CHAR) AS skewness FROM skew_data;
DELETE FROM skew_data;

# --- Single row: returns NULL (variance undefined) ---
INSERT INTO skew_data VALUES (42);
SELECT CAST(STATS_SKEWNESS(val) AS CHAR) AS skewness FROM skew_data;
DELETE FROM skew_data;

# --- Two rows: minimum n; symmetric pair gives moment=0, pearson=0 ---
INSERT INTO skew_data VALUES (1),(3);
SELECT CAST(STATS_SKEWNESS(val) AS CHAR) AS skewness FROM skew_data;
DELETE FROM skew_data;

# --- All equal values: variance is zero, both fields are null ---
INSERT INTO skew_data VALUES (5),(5),(5),(5),(5);
SELECT CAST(STATS_SKEWNESS(val) AS CHAR) AS skewness FROM skew_data;
DELETE FROM skew_data;

DROP TABLE skew_data;

# --- GROUP BY: skewness computed independently per group ---
CREATE TABLE vsql_test.skew_grouped (grp INT, val DOUBLE);
INSERT INTO skew_grouped VALUES
  (1,1),(1,2),(1,3),(1,4),(1,5),
  (2,2),(2,4),(2,4),(2,4),(2,5),(2,5),(2,7),(2,9);
SELECT grp,
  CAST(STATS_SKEWNESS(val) AS CHAR) AS skewness
FROM vsql_test.skew_grouped
GROUP BY grp
ORDER BY grp;
DROP TABLE vsql_test.skew_grouped;
DROP DATABASE vsql_test;

UNINSTALL EXTENSION vsql_statistics;
