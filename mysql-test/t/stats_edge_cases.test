# stats_edge_cases.test: Test critical value limits and trim boundaries
INSTALL EXTENSION vsql_statistics;
CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;

# 1. Trim percentage boundary checks (p >= 0.5 makes trimmed/winsorized null)
CREATE TABLE t_trim (val DOUBLE);
INSERT INTO t_trim VALUES (10.0), (20.0), (30.0), (40.0);
SELECT JSON_EXTRACT(CAST(STATS_MEAN(val, 0.5) AS CHAR), '$.trimmed') AS trim_50,
       JSON_EXTRACT(CAST(STATS_MEAN(val, 0.6) AS CHAR), '$.winsorized') AS wins_60
FROM t_trim;
DROP TABLE t_trim;

# 2. Dynamic critical value bisection limits for tiny alpha
CREATE TABLE t_ttest (val DOUBLE, grp INT);
INSERT INTO t_ttest VALUES (10.0, 1), (12.0, 1), (50.0, 2), (52.0, 2);
# alpha = 1e-6 (standard fixed bisection would cap at 1000.0): t_crit_one_tail > 0
SELECT JSON_EXTRACT(CAST(STATS_TTEST(val, grp, 1e-6) AS CHAR), '$.t_crit_one_tail') > 0 AS crit_val_exists FROM t_ttest;
# invalid alpha values produce null for critical value fields
SELECT JSON_EXTRACT(CAST(STATS_TTEST(val, grp, -0.05) AS CHAR), '$.t_crit_one_tail') AS crit_neg,
       JSON_EXTRACT(CAST(STATS_TTEST(val, grp,  1.05) AS CHAR), '$.t_crit_one_tail') AS crit_large
FROM t_ttest;
DROP TABLE t_ttest;

DROP DATABASE vsql_test;
UNINSTALL EXTENSION vsql_statistics;
