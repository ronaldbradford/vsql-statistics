# vsql_statistics: One-way ANOVA (Analysis of Variance)
INSTALL EXTENSION vsql_statistics;
# --- Spec test vector: k=3, n_j=5 ---
# Group 1: {4,6,8,7,5}   mean=6, SSw=10
# Group 2: {1,3,2,4,5}   mean=3, SSw=10
# Group 3: {8,10,9,7,11} mean=9, SSw=10
# Grand mean=6, SSB=90, SSW=30, SST=120, dfB=2, dfW=12, MSB=45, MSW=2.5, F=18
CREATE TABLE anova_spec (value DOUBLE, grp INT);
INSERT INTO anova_spec VALUES
(4,1),(6,1),(8,1),(7,1),(5,1),
(1,2),(3,2),(2,2),(4,2),(5,2),
(8,3),(10,3),(9,3),(7,3),(11,3);
SELECT CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova FROM anova_spec;
anova
{"f":18,"p":0.000244140625,"ssb":90,"ssw":30,"sst":120,"msb":45,"msw":2.5,"df_b":2,"df_w":12}
DROP TABLE anova_spec;
# --- Equal group means: SSB=0, F=0, p=1 ---
CREATE TABLE anova_equal (value DOUBLE, grp INT);
INSERT INTO anova_equal VALUES
(1,1),(2,1),(3,1),
(1,2),(2,2),(3,2),
(1,3),(2,3),(3,3);
SELECT CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova FROM anova_equal;
anova
{"f":0,"p":1,"ssb":0,"ssw":6,"sst":6,"msb":0,"msw":1,"df_b":2,"df_w":6}
DROP TABLE anova_equal;
# --- NULL values are ignored: same result as spec test vector ---
CREATE TABLE anova_with_nulls (value DOUBLE, grp INT);
INSERT INTO anova_with_nulls VALUES
(4,1),(6,1),(8,1),(7,1),(5,1),
(1,2),(3,2),(2,2),(4,2),(5,2),
(8,3),(10,3),(9,3),(7,3),(11,3),
(NULL,1),(NULL,2),(NULL,3);
SELECT CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova FROM anova_with_nulls;
anova
{"f":18,"p":0.000244140625,"ssb":90,"ssw":30,"sst":120,"msb":45,"msw":2.5,"df_b":2,"df_w":12}
DROP TABLE anova_with_nulls;
# --- Edge case: only one distinct group returns NULL ---
CREATE TABLE anova_one_group (value DOUBLE, grp INT);
INSERT INTO anova_one_group VALUES (4,1),(6,1),(8,1);
SELECT CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova FROM anova_one_group;
anova
NULL
DROP TABLE anova_one_group;
# --- Edge case: group with a single observation returns NULL ---
CREATE TABLE anova_singleton (value DOUBLE, grp INT);
INSERT INTO anova_singleton VALUES
(1,1),
(2,2),(3,2),(4,2),
(5,3),(6,3),(7,3);
SELECT CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova FROM anova_singleton;
anova
NULL
DROP TABLE anova_singleton;
# --- Edge case: all-NULL input returns NULL ---
CREATE TABLE anova_all_null (value DOUBLE, grp INT);
INSERT INTO anova_all_null VALUES
(NULL,1),(NULL,1),(NULL,2),(NULL,2),(NULL,3),(NULL,3);
SELECT CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova FROM anova_all_null;
anova
NULL
DROP TABLE anova_all_null;
# --- Edge case: zero within-group variance returns NULL (MSW=0) ---
CREATE TABLE anova_zero_within (value DOUBLE, grp INT);
INSERT INTO anova_zero_within VALUES
(5,1),(5,1),(5,1),
(10,2),(10,2),(10,2),
(15,3),(15,3),(15,3);
SELECT CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova FROM anova_zero_within;
anova
NULL
DROP TABLE anova_zero_within;
# --- k=2 groups: allowed; equivalent to pooled t-test (F = t² = 1) ---
# Same data as the STATS_TTEST basic dataset where t=1.0
CREATE TABLE anova_two_groups (value DOUBLE, grp INT);
INSERT INTO anova_two_groups VALUES
(100,1),(110,1),(120,1),(130,1),(140,1),
(90,2),(100,2),(110,2),(120,2),(130,2);
SELECT CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova FROM anova_two_groups;
anova
{"f":1,"p":0.346593507087334,"ssb":250,"ssw":2000,"sst":2250,"msb":250,"msw":250,"df_b":1,"df_w":8}
DROP TABLE anova_two_groups;
# --- GROUP BY: two independent ANOVA tests in one query ---
# Exp 1: spec vector, F=18
# Exp 2: groups {10-14},{20-24},{30-34} — same within spread, larger between, F=200
CREATE TABLE anova_grouped (exp_id INT, value DOUBLE, grp INT);
INSERT INTO anova_grouped VALUES
(1, 4,1),(1, 6,1),(1, 8,1),(1, 7,1),(1, 5,1),
(1, 1,2),(1, 3,2),(1, 2,2),(1, 4,2),(1, 5,2),
(1, 8,3),(1,10,3),(1, 9,3),(1, 7,3),(1,11,3),
(2,10,1),(2,12,1),(2,14,1),(2,11,1),(2,13,1),
(2,20,2),(2,22,2),(2,24,2),(2,21,2),(2,23,2),
(2,30,3),(2,32,3),(2,34,3),(2,31,3),(2,33,3);
SELECT exp_id,
CAST(STATS_ANOVA(value, grp) AS CHAR) AS anova
FROM anova_grouped
GROUP BY exp_id
ORDER BY exp_id;
exp_id	anova
1	{"f":18,"p":0.000244140625,"ssb":90,"ssw":30,"sst":120,"msb":45,"msw":2.5,"df_b":2,"df_w":12}
2	{"f":200,"p":0.000000000610526,"ssb":1000,"ssw":30,"sst":1030,"msb":500,"msw":2.5,"df_b":2,"df_w":12}
DROP TABLE anova_grouped;
UNINSTALL EXTENSION vsql_statistics;
