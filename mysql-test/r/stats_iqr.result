# vsql_statistics: IQR family aggregate functions
INSTALL EXTENSION vsql_statistics;
# --- Coffee shop dataset (9 integer rows) with CAST for decimal output ---
# INT columns require CAST(col AS DOUBLE) to get decimal-precision results.
CREATE TABLE espresso_sales (
daily_count INT NOT NULL CHECK (daily_count >= 0)
);
INSERT INTO espresso_sales VALUES (7),(12),(15),(11),(4),(18),(14),(11),(30);
SELECT STATS_IQR(CAST(daily_count AS DOUBLE))             AS iqr            FROM espresso_sales;
iqr
7.5
SELECT STATS_Q1(CAST(daily_count AS DOUBLE))              AS q1             FROM espresso_sales;
q1
9
SELECT STATS_Q3(CAST(daily_count AS DOUBLE))              AS q3             FROM espresso_sales;
q3
16.5
SELECT STATS_MEDIAN(CAST(daily_count AS DOUBLE))          AS median         FROM espresso_sales;
median
12
SELECT STATS_IQR_LOWER_FENCE(CAST(daily_count AS DOUBLE)) AS lower_fence    FROM espresso_sales;
lower_fence
-2.25
SELECT STATS_IQR_UPPER_FENCE(CAST(daily_count AS DOUBLE)) AS upper_fence    FROM espresso_sales;
upper_fence
27.75
# --- INT column without CAST returns integer-rounded results (expected) ---
SELECT STATS_IQR(daily_count)    AS iqr_int FROM espresso_sales;
iqr_int
8
SELECT STATS_MEDIAN(daily_count) AS med_int FROM espresso_sales;
med_int
12
# --- Edge case: single row ---
CREATE TABLE single_row (v INT NOT NULL CHECK (v >= 0));
INSERT INTO single_row VALUES (12);
SELECT STATS_IQR(CAST(v AS DOUBLE)) AS iqr FROM single_row;
iqr
0
# --- Edge case: two rows ---
CREATE TABLE two_rows (v INT NOT NULL CHECK (v >= 0));
INSERT INTO two_rows VALUES (5),(15);
SELECT STATS_IQR(CAST(v AS DOUBLE)) AS iqr FROM two_rows;
iqr
10
# --- Edge case: all-NULL group ---
CREATE TABLE nullable_vals (v DOUBLE);
INSERT INTO nullable_vals VALUES (NULL),(NULL),(NULL);
SELECT STATS_IQR(v) AS iqr FROM nullable_vals;
iqr
NULL
# --- Multiple groups via GROUP BY ---
CREATE TABLE grouped_sales (region VARCHAR(10), amount INT NOT NULL CHECK (amount >= 0));
INSERT INTO grouped_sales VALUES
('East',4),('East',7),('East',11),('East',11),('East',12),
('East',14),('East',15),('East',18),('East',30),
('West',1),('West',3),('West',5),('West',5),('West',6),
('West',7),('West',8),('West',9),('West',10);
SELECT region, STATS_IQR(CAST(amount AS DOUBLE)) AS iqr FROM grouped_sales GROUP BY region ORDER BY region;
region	iqr
East	7.5
West	4.5
DROP TABLE espresso_sales, single_row, two_rows, nullable_vals, grouped_sales;
UNINSTALL EXTENSION vsql_statistics;
