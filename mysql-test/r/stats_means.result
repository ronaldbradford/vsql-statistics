# vsql_statistics: trimmed, Winsorized, geometric, and harmonic means
INSTALL EXTENSION vsql_statistics;
CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;
# --- Spec example {2,10,12,14,15,18,100} at 20% trim ---
# trimmed: removes 1 from each end → mean({10,12,14,15,18})=13.8
# winsorized: 2→10, 100→18; sum=97, mean=97/7≈13.857
# geometric: ⁷√(2×10×12×14×15×18×100)
# harmonic: 7/(1/2+1/10+1/12+1/14+1/15+1/18+1/100)
CREATE TABLE means_data (val DOUBLE, trim_pct DOUBLE);
INSERT INTO means_data VALUES (2,0.2),(10,0.2),(12,0.2),(14,0.2),(15,0.2),(18,0.2),(100,0.2);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
means
{"trimmed":13.8,"winsorized":13.8571428571429,"geometric":13.7029704195523,"harmonic":7.89191123836793}
DELETE FROM means_data;
# --- trim=0: trimmed/winsorized equal arithmetic mean ---
INSERT INTO means_data VALUES (2,0),(10,0),(12,0),(14,0),(15,0),(18,0),(100,0);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
means
{"trimmed":24.4285714285714,"winsorized":24.4285714285714,"geometric":13.7029704195523,"harmonic":7.89191123836793}
DELETE FROM means_data;
# --- NULL trim_pct: trimmed and winsorized are null ---
INSERT INTO means_data VALUES (1.05,NULL),(1.10,NULL),(1.20,NULL);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
means
{"trimmed":null,"winsorized":null,"geometric":1.11494747954535,"harmonic":1.11325301204819}
DELETE FROM means_data;
# --- Degenerate trim (all values removed): trimmed/winsorized null ---
# trim_pct=0.5, n=2: k=floor(0.5*2)=1, 2k=2>=n=2
INSERT INTO means_data VALUES (10,0.5),(20,0.5);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
means
{"trimmed":null,"winsorized":null,"geometric":14.142135623731,"harmonic":13.3333333333333}
DELETE FROM means_data;
# --- All-NULL values: whole result is NULL ---
INSERT INTO means_data VALUES (NULL,0.2),(NULL,0.2);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
means
NULL
DELETE FROM means_data;
# --- Non-positive values: skipped for geometric/harmonic ---
INSERT INTO means_data VALUES (-1,0.2),(0,0.2),(10,0.2),(20,0.2),(30,0.2);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
means
{"trimmed":10,"winsorized":10,"geometric":18.1712059283214,"harmonic":16.3636363636364}
DELETE FROM means_data;
# --- All non-positive: geometric/harmonic are null ---
INSERT INTO means_data VALUES (-5,NULL),(-3,NULL),(0,NULL);
SELECT CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means FROM means_data;
means
{"trimmed":null,"winsorized":null,"geometric":null,"harmonic":null}
DELETE FROM means_data;
DROP TABLE means_data;
# --- GROUP BY: means computed independently per group ---
CREATE TABLE vsql_test.means_grouped (grp INT, val DOUBLE, trim_pct DOUBLE);
INSERT INTO means_grouped VALUES
(1, 2,   0.2),(1, 10,  0.2),(1, 12,  0.2),(1, 14,  0.2),
(1, 15,  0.2),(1, 18,  0.2),(1, 100, 0.2),
(2, 1.05,NULL),(2, 1.10,NULL),(2, 1.20,NULL);
SELECT grp,
CAST(STATS_MEAN(val, trim_pct) AS CHAR) AS means
FROM vsql_test.means_grouped
GROUP BY grp
ORDER BY grp;
grp	means
1	{"trimmed":13.8,"winsorized":13.8571428571429,"geometric":13.7029704195523,"harmonic":7.89191123836793}
2	{"trimmed":null,"winsorized":null,"geometric":1.11494747954535,"harmonic":1.11325301204819}
DROP TABLE vsql_test.means_grouped;
DROP DATABASE vsql_test;
UNINSTALL EXTENSION vsql_statistics;
