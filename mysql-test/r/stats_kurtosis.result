INSTALL EXTENSION vsql_statistics;
CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;
CREATE TABLE kurt_data (val DOUBLE);
INSERT INTO kurt_data VALUES (10),(12),(15),(18),(20);
SELECT CAST(STATS_KURTOSIS(val) AS CHAR) AS kurtosis FROM kurt_data;
kurtosis
{"kurtosis":1.52681660899654,"excess":-1.89273356401384}
DELETE FROM kurt_data;
INSERT INTO kurt_data VALUES (1),(2),(3),(4),(5);
SELECT CAST(STATS_KURTOSIS(val) AS CHAR) AS kurtosis FROM kurt_data;
kurtosis
{"kurtosis":1.7,"excess":-1.2}
DELETE FROM kurt_data;
INSERT INTO kurt_data VALUES (1),(2),(3);
SELECT CAST(STATS_KURTOSIS(val) AS CHAR) AS kurtosis FROM kurt_data;
kurtosis
{"kurtosis":1.5,"excess":null}
DELETE FROM kurt_data;
INSERT INTO kurt_data VALUES (NULL),(NULL),(NULL);
SELECT CAST(STATS_KURTOSIS(val) AS CHAR) AS kurtosis FROM kurt_data;
kurtosis
NULL
DELETE FROM kurt_data;
INSERT INTO kurt_data VALUES (5),(5),(5),(5),(5);
SELECT CAST(STATS_KURTOSIS(val) AS CHAR) AS kurtosis FROM kurt_data;
kurtosis
{"kurtosis":null,"excess":null}
DELETE FROM kurt_data;
INSERT INTO kurt_data VALUES (42);
SELECT CAST(STATS_KURTOSIS(val) AS CHAR) AS kurtosis FROM kurt_data;
kurtosis
NULL
DROP TABLE kurt_data;
CREATE TABLE vsql_test.kurt_grouped (grp INT, val DOUBLE);
INSERT INTO kurt_grouped VALUES
(1, 10),(1, 12),(1, 15),(1, 18),(1, 20),
(2,  1),(2,  2),(2,  3),(2,  4),(2,  5);
SELECT grp,
CAST(STATS_KURTOSIS(val) AS CHAR) AS kurtosis
FROM vsql_test.kurt_grouped
GROUP BY grp
ORDER BY grp;
grp	kurtosis
1	{"kurtosis":1.52681660899654,"excess":-1.89273356401384}
2	{"kurtosis":1.7,"excess":-1.2}
DROP TABLE vsql_test.kurt_grouped;
DROP DATABASE vsql_test;
UNINSTALL EXTENSION vsql_statistics;
