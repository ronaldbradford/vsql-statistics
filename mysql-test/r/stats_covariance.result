INSTALL EXTENSION vsql_statistics;
CREATE DATABASE IF NOT EXISTS vsql_test;
USE vsql_test;
CREATE TABLE cov_data (x DOUBLE, y DOUBLE);
INSERT INTO cov_data VALUES (2,5),(4,10),(6,12);
SELECT ROUND(STATS_COVARIANCE_POP(x, y), 4)  AS pop_covariance  FROM cov_data;
pop_covariance
4.6667
SELECT ROUND(STATS_COVARIANCE_SAMP(x, y), 4) AS samp_covariance FROM cov_data;
samp_covariance
7
DELETE FROM cov_data;
INSERT INTO cov_data VALUES (1,20),(3,15),(5,10);
SELECT ROUND(STATS_COVARIANCE_POP(x, y), 4)  AS pop_covariance  FROM cov_data;
pop_covariance
-6.6667
SELECT ROUND(STATS_COVARIANCE_SAMP(x, y), 4) AS samp_covariance FROM cov_data;
samp_covariance
-10
DELETE FROM cov_data;
INSERT INTO cov_data VALUES (1,2),(2,4),(3,6),(4,8),(5,10);
SELECT ROUND(STATS_COVARIANCE_POP(x, y), 4)  AS pop_covariance  FROM cov_data;
pop_covariance
4
SELECT ROUND(STATS_COVARIANCE_SAMP(x, y), 4) AS samp_covariance FROM cov_data;
samp_covariance
5
DELETE FROM cov_data;
INSERT INTO cov_data VALUES (3,7);
SELECT STATS_COVARIANCE_POP(x, y)  AS pop_single  FROM cov_data;
pop_single
0
SELECT STATS_COVARIANCE_SAMP(x, y) AS samp_single FROM cov_data;
samp_single
NULL
DELETE FROM cov_data;
INSERT INTO cov_data VALUES (NULL,NULL),(NULL,NULL);
SELECT STATS_COVARIANCE_POP(x, y)  AS pop_null  FROM cov_data;
pop_null
NULL
SELECT STATS_COVARIANCE_SAMP(x, y) AS samp_null FROM cov_data;
samp_null
NULL
DELETE FROM cov_data;
INSERT INTO cov_data VALUES (2,5),(NULL,10),(6,NULL);
SELECT STATS_COVARIANCE_POP(x, y)  AS pop_skip  FROM cov_data;
pop_skip
0
SELECT STATS_COVARIANCE_SAMP(x, y) AS samp_skip FROM cov_data;
samp_skip
NULL
DROP TABLE cov_data;
CREATE TABLE vsql_test.cov_grouped (grp INT, x DOUBLE, y DOUBLE);
INSERT INTO cov_grouped VALUES
(1, 2,5),(1, 4,10),(1, 6,12),
(2, 1,20),(2, 3,15),(2, 5,10);
SELECT grp,
ROUND(STATS_COVARIANCE_POP(x, y), 4)  AS pop_covariance,
ROUND(STATS_COVARIANCE_SAMP(x, y), 4) AS samp_covariance
FROM vsql_test.cov_grouped
GROUP BY grp
ORDER BY grp;
grp	pop_covariance	samp_covariance
1	4.6667	7
2	-6.6667	-10
DROP TABLE vsql_test.cov_grouped;
DROP DATABASE vsql_test;
UNINSTALL EXTENSION vsql_statistics;
